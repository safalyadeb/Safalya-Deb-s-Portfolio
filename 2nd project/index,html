      z-index:1000;

    }



    .logo{

      font-size:55px;

      font-weight:900;

      color:#3b5bff;

    }



    nav a{

      color:white;

      text-decoration:none;

      margin-left:35px;

      font-size:22px;

      font-weight:700;

      transition:.3s;

    }



    nav a:hover,

    nav a.active{

      color:#3b5bff;

      text-decoration:underline;

    }



    /* HOME */



    .home{

      display:flex;

      justify-content:space-between;

      align-items:center;

      gap:50px;

    }



    .home-text{

