      align-items:center;

      justify-content:space-between;

      gap:60px;

    }



    .about-text{

      flex:1;

    }



    .about-text p{

      font-size:28px;

      line-height:1.8;

      color:#d1d5db;

      margin-bottom:25px;

    }



    .about-text span{

      color:#3b5bff;

      font-weight:bold;

    }



    .about-image{

      flex:1;

      position:relative;

    }



    .about-image img{

      width:100%;

      border-radius:25px;

    }



    .experience-card{

      position:absolute;

      right:-30px;

      top:50%;

