    }



    .home-text h3{

      font-size:65px;

      margin-bottom:10px;

    }



    .home-text h1{

      font-size:95px;

      color:#3b5bff;

      margin-bottom:10px;

      font-weight:900;

    }



    .home-text h2{

      font-size:60px;

      margin-bottom:20px;

    }



    .home-text p{

      font-size:28px;

      color:#d1d5db;

      line-height:1.7;

    }



    .btn-box{

      margin-top:35px;

      display:flex;

      gap:20px;

      flex-wrap:wrap;

    }



    .btn{

      padding:18px 40px;

      background:#3b5bff;

      color:white;

      border-radius:12px;

      text-decoration:none;

      font-size:22px;

      font-weight:bold;

      transition:.3s;

      border:none;

      cursor:pointer;

    }



    .btn:hover{

      transform:translateY(-5px);

      box-shadow:0 0 25px #3b5bff;

    }



    .btn-outline{

      background:transparent;

      border:2px solid #3b5bff;

    }



    .socials{

      margin-top:40px;

    }



    .socials a{

      color:white;

      font-size:35px;

      margin-right:20px;

      transition:.3s;

    }



    .socials a:hover{

      color:#3b5bff;

    }



    .home-image{

      position:relative;

    }



    .home-image img{

      width:500px;

      height:500px;

      border-radius:50%;

      border:5px solid #3b5bff;

      object-fit:cover;

      box-shadow:0 0 40px #3b5bff;

    }



    .code-icon{

      position:absolute;

      right:-20px;

      top:50%;

      transform:translateY(-50%);

      background:#3b5bff;

      width:90px;

      height:90px;

      display:flex;

      align-items:center;

      justify-content:center;

      border-radius:20px;

      font-size:40px;

      box-shadow:0 0 20px #3b5bff;

    }



    /* TITLES */



